<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.EditarPerroController">
   <children>
      <HBox alignment="CENTER" prefHeight="50.0">
         <children>
            <Label text="EDITAR INFORMACIÓN DEL PERRO" textFill="#888888">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
         </children>
      </HBox>

      <HBox spacing="40.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <StackPane prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 15; -fx-border-color: #ddd; -fx-border-radius: 15;">
                     <children>
                        <ImageView fx:id="imgPreview" fitHeight="180.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </StackPane>
                  <Button onAction="#onSeleccionarImagen" style="-fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 20; -fx-background-radius: 20;" text="Cambiar Foto" />
                  <Label fx:id="lblRutaImagen" text="..." textFill="#aaaaaa">
                     <font><Font size="10.0" /></font>
                  </Label>
               </children>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <GridPane hgap="15.0" vgap="15.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Label text="Nombre:" />
                        <TextField fx:id="txtNombre" style="-fx-background-radius: 10;" GridPane.columnIndex="1" />
                        
                        <Label text="Raza:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtRaza" style="-fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Edad:" GridPane.rowIndex="2" />
                        <TextField fx:id="txtEdad" style="-fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Sexo:" GridPane.rowIndex="3" />
                        <ComboBox fx:id="cbSexo" prefWidth="250.0" style="-fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <Label text="Tamaño:" GridPane.rowIndex="4" />
                        <ComboBox fx:id="cbTamanio" prefWidth="250.0" style="-fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                     </children>
                  </GridPane>

                  <Separator />
                  
                  <Label text="Descripción" textFill="#888888" />
                  <TextArea fx:id="txtDescripcion" prefHeight="80.0" style="-fx-background-radius: 10;" wrapText="true" />
                  
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button onAction="#onCancelar" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 20;" text="Cancelar" />
                        <Button onAction="#onGuardarCambios" prefWidth="140.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 20;" text="Guardar Cambios" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
</VBox>