<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.DetallePerroController">
   <children>
      
      <HBox alignment="CENTER" prefHeight="50.0">
         <children>
            <Label text="FICHA DETALLADA DEL PERRO" textFill="#888888">
               <font>
                  <Font name="System Bold" size="18.0" /> 
               </font>
            </Label>
         </children>
      </HBox>
      
      <HBox spacing="30.0">
         <children>
            <VBox alignment="TOP_CENTER" spacing="15.0">
               <children>
                  <StackPane prefHeight="220.0" prefWidth="220.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 15; -fx-border-color: #ddd; -fx-border-radius: 15;">
                     <children>
                        <ImageView fx:id="imgPerro" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                     </children>
                  </StackPane>
                  <Label fx:id="lblNombre" text="Nombre">
                     <font><Font name="System Bold" size="32.0" /></font>
                  </Label>
                  <Label fx:id="lblEstado" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 20;" text="Disponible">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
               </children>
            </VBox>
            
            <Separator orientation="VERTICAL" />

            <VBox spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <GridPane hgap="10.0" vgap="15.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Label text="Raza:" /> <Label fx:id="lblRaza" text="---" GridPane.columnIndex="1" />
                        <Label text="Edad:" GridPane.rowIndex="1" /> <Label fx:id="lblEdad" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Sexo:" GridPane.rowIndex="2" /> <Label fx:id="lblSexo" text="---" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Tamaño:" GridPane.rowIndex="3" /> <Label fx:id="lblTamanio" text="---" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </children>
                  </GridPane>
                  
                  <Separator />
                  
                  <Label text="Información Adicional" textFill="#888888" />
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Descripción" />
                        <Label fx:id="lblDescripcion" text="Sin descripción disponible." wrapText="true" />
                     </children>
                  </VBox>
                  
                  <Region VBox.vgrow="ALWAYS" />
                  
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
   <children>
      <Button onAction="#onEditarClick" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 20; -fx-background-radius: 20;" text="Editar" />
      
      <Button onAction="#onBorrarClick" prefWidth="120.0" style="-fx-border-color: #f89c51; -fx-text-fill: #f89c51; -fx-background-color: white; -fx-border-radius: 20; -fx-background-radius: 20;" text="Borrar" />
   </children>
</HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
</VBox>