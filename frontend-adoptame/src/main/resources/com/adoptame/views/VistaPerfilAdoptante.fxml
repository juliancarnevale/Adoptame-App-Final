<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.PerfilAdoptanteController">
   <padding>
      <Insets bottom="50.0" left="40.0" right="40.0" top="50.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" maxWidth="900.0">
         <children>
            <Label text="Mi Perfil" textFill="BLACK">
               <font><Font name="System Bold" size="32.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#onVolverAlCatalogo" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 20; -fx-cursor: hand;" text="Volver al Catálogo" />
         </children>
      </HBox>
      
      <VBox alignment="CENTER" maxWidth="500.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
         <children>
            <StackPane>
               <children>
                  <ImageView fx:id="imgPerfil" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/images/logi.png" />
                     </image>
                  </ImageView>
               </children>
            </StackPane>
            <Button onAction="#onCambiarFoto" text="Cambiar Foto" />
            
            <VBox spacing="10.0" maxWidth="400.0">
               <children>
                  <Label text="Nombre Completo" textFill="#666666"><font><Font name="System Bold" size="12.0" /></font></Label>
                  <TextField fx:id="txtNombre" prefHeight="40.0" />
                  
                  <Label text="Correo Electrónico" textFill="#666666"><font><Font name="System Bold" size="12.0" /></font></Label>
                  <TextField fx:id="txtEmail" prefHeight="40.0" />
                  
                  <Label text="Teléfono" textFill="#666666"><font><Font name="System Bold" size="12.0" /></font></Label>
                  <TextField fx:id="txtTelefono" prefHeight="40.0" />
               </children>
            </VBox>
            
            <Button onAction="#onGuardarCambios" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="Guardar Cambios">
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>