<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.CambiarEstadoController">
   <children>
      <HBox alignment="CENTER" prefHeight="50.0">
         <children>
            <Label text="GESTIÓN DE ESTADOS" textFill="#888888">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
         </children>
      </HBox>

      <HBox spacing="15.0" alignment="CENTER_LEFT">
         <children>
            <TextField fx:id="txtBuscador" prefWidth="300.0" promptText="Buscar perro por nombre..." style="-fx-background-radius: 20;" />
            <Label text="Selecciona un perro para actualizar su situación" textFill="#aaaaaa" />
         </children>
      </HBox>

      <HBox spacing="30.0" VBox.vgrow="ALWAYS">
         <children>
            <ListView fx:id="lvPerros" prefWidth="300.0" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />

            <VBox fx:id="panelAccion" alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #f9f9f9; -fx-background-radius: 15; -fx-border-color: #eee; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
               <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
               <children>
                  <ImageView fx:id="imgPerro" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                  <Label fx:id="lblNombre" text="Selecciona un perro">
                     <font><Font name="System Bold" size="24.0" /></font>
                  </Label>
                  <Label fx:id="lblEstadoActual" text="Estado actual: ---" textFill="#888888" />
                  
                  <Separator prefWidth="200.0" />
                  
                  <Label text="Cambiar estado a:" />
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Button onAction="#onMarcarDisponible" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 20;" text="Disponible" />
                        <Button onAction="#onMarcarAdoptado" prefWidth="120.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 20;" text="Adoptado" />
                        <Button onAction="#onMarcarRevision" prefWidth="120.0" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 20;" text="En Revisión" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
</VBox>