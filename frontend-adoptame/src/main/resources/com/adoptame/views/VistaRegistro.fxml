<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #E0E0E0;" stylesheets="@estilos-app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.RegistroController">
   <children>
      <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox alignment="CENTER" spacing="20.0">
               <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
               <children>
                  <VBox alignment="TOP_CENTER" maxWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 30;">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image><Image url="@/images/logi.png" /></image>
                        </ImageView>
                        
                        <Label text="Crear Cuenta" style="-fx-text-fill: #333333; -fx-font-size: 24px; -fx-font-weight: bold;" />
                        
                        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0;">
                           <children>
                              <RadioButton fx:id="rbAdoptante" selected="true" text="Adoptante" style="-fx-text-fill: #333333; -fx-font-size: 14px;">
                                 <toggleGroup><ToggleGroup fx:id="tipoCuentaGroup" /></toggleGroup>
                              </RadioButton>
                              <RadioButton fx:id="rbAsociacion" text="Asociación / Admin" toggleGroup="$tipoCuentaGroup" style="-fx-text-fill: #333333; -fx-font-size: 14px;" />
                           </children>
                        </HBox>

                        <VBox fx:id="boxProtectora" managed="false" spacing="5.0" visible="false">
                           <Label text="Nombre de la Protectora" style="-fx-text-fill: #666666; -fx-font-weight: bold; -fx-font-size: 12px;" />
                           <TextField fx:id="txtProtectora" promptText="Ej: Huellas Felices" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Nombre completo de la persona" style="-fx-text-fill: #666666; -fx-font-weight: bold; -fx-font-size: 12px;" />
                           <TextField fx:id="txtNombre" promptText="Nombre y apellidos" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Correo electrónico" style="-fx-text-fill: #666666; -fx-font-weight: bold; -fx-font-size: 12px;" />
                           <TextField fx:id="txtCorreo" promptText="ejemplo@correo.com" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <VBox spacing="5.0">
                           <Label text="Teléfono" style="-fx-text-fill: #666666; -fx-font-weight: bold; -fx-font-size: 12px;" />
                           <TextField fx:id="txtTelefono" promptText="Ej: 600123456" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <Separator />
                        <Label text="Dirección" style="-fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 14px;" />
                        
                        <VBox spacing="5.0">
                           <Label text="Calle y número" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
                           <TextField fx:id="txtCalle" promptText="Calle..." prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <HBox spacing="10.0">
                           <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                              <Label text="Código Postal" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
                              <TextField fx:id="txtCP" promptText="C.P." prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                           </VBox>
                           <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                              <Label text="Localidad" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
                              <TextField fx:id="txtLocalidad" promptText="Ciudad" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                           </VBox>
                        </HBox>

                        <VBox spacing="5.0">
                           <Label text="Provincia" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
                           <TextField fx:id="txtProvincia" promptText="Provincia" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>
                        
                        <Separator />

                        <VBox spacing="5.0">
                           <Label text="Contraseña" style="-fx-text-fill: #666666; -fx-font-weight: bold; -fx-font-size: 12px;" />
                           <PasswordField fx:id="txtPassword" promptText="Crea una contraseña" prefHeight="35.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cccccc;" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="10.0">
                           <VBox.margin><Insets top="15.0" /></VBox.margin>
                           <children>
                              <Button onAction="#onRegistrarClick" maxWidth="1.7976931348623157E308" prefHeight="40.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" text="Registrarse y Entrar" />
                              <Button onAction="#onVolverClick" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-underline: true; -fx-cursor: hand;" text="Ya tengo cuenta. Volver al Login" />
                           </children>
                        </VBox>

                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>