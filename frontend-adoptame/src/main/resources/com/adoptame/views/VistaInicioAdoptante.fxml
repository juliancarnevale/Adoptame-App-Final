<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f4f4f4;" stylesheets="@estilos-app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.adoptame.controllers.InicioAdoptanteController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15 30; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@/images/logi.png" />
               </image>
            </ImageView>
            <Label text="AdoptaMe" textFill="#333333">
               <font><Font name="System Bold" size="26.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <ImageView fx:id="imgUserAvatar" fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@/images/logi.png" /> 
                     </image>
                  </ImageView>
                  <Button onAction="#onMisSolicitudes" style="-fx-background-color: transparent; -fx-text-fill: #333333; -fx-cursor: hand;" text="Mis Solicitudes">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Button>
               </children>
            </HBox>
            
            <Button onAction="#onPerfil" style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;" text="Perfil" />
            <Button onAction="#onCerrarSesion" style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 20; -fx-padding: 8 15; -fx-text-fill: #cc0000; -fx-cursor: hand;" text="Cerrar Sesión" />
         </children>
      </HBox>
   </top>
   <center>
      <StackPane fx:id="contentArea" />
   </center>
</BorderPane>